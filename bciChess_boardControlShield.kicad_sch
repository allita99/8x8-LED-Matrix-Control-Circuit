	(text "Inverting Drivers\nIC 3,4 7,8 11,12 15,16"
		(exclude_from_sim no)
		(at 265.43 15.24 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "1047c3b1-7f01-4604-9c5c-5d386942ab80")
	)
	(text "Each box LED here represents connections required (They do not exist in the PCB design)\nEach cell contains 10 LEDs at 15v 40ma = 0.6w\nEach PMOS has 40mA current through\nEach NMOS has 320mA current through."
		(exclude_from_sim no)
		(at 248.92 248.92 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "18624768-480e-4cc5-badb-1e0d7acbfe86")
	)
	(text "LM812 \neff at 20V 0.7 A => 8,19 / 14.06 58,2% T=100C\neff at 19V 0.7A   8,131 / 13,3 61,1% T=100C\neff at 15V 0.704A 8,27 / 10,59 78%  T=70C\n\nStep Down Converter \neff at 20V  8,45 / 10,1 83,7%   T=65C "
		(exclude_from_sim no)
		(at 128.524 59.944 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "1bdcc44a-8b39-4a9c-9f68-cf558af5277b")
	)
	(text "Power Draw(1):\n12V 4x4 LED per block 80mA => 0,96W | 58,88W at 100% eff\nTotal amp needed = 80mA * 64 \n=> 5.12 A at 12V for continuous brightness\nPower Draw(2):\n15V 5x2 LED per block 40mA => 0,60W | 38.4W at 100% eff\nTotal amp needed = 40mA * 64 \n=> 2.56 A at 15V for continuous brightness eff -> 76% eff need ~50,52\n"
		(exclude_from_sim no)
		(at 128.27 77.47 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "3444abee-be7e-41ef-b735-8312cbf8d30e")
	)
